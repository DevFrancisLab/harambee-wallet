DJANGO_SECRET_KEY=dev-secret-for-hackathon-change-in-production
DJANGO_DEBUG=1

# UTXOS SDK Configuration (server-side only - NEVER expose to frontend)
UTXOS_API_KEY=your-utxos-api-key-here
UTXOS_PROJECT_ID=your-utxos-project-id-here

# Database (optional, uses SQLite by default)
# DATABASE_URL=sqlite:///db.sqlite3

# Allowed hosts for CORS
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:3000,localhost:5173